# ScreenTrace 环境变量配置
# 复制此文件为 .env 并填写您的配置

# ==========================================
# API配置
# ==========================================

# API密钥（必填）
SCREENTRACE_API_KEY=your_api_key_here

# API提供商（可选：openai, claude, gemini, custom）
SCREENTRACE_API_PROVIDER=openai

# API基础URL（自定义URL时使用）
# OpenAI默认：https://api.openai.com/v1
# Claude默认：https://api.anthropic.com/v1
# Gemini默认：https://generativelanguage.googleapis.com/v1
# 自定义示例：http://localhost:11434/v1（Ollama）
SCREENTRACE_API_BASE_URL=https://api.openai.com/v1

# API模型名称
SCREENTRACE_API_MODEL=gpt-4-vision-preview

# API兼容模式（决定如何构造请求）
# openai：使用OpenAI格式（适用于大多数兼容服务）
# claude：使用Claude格式
# gemini：使用Gemini格式
# 默认使用provider的值，如果provider是custom则默认openai
SCREENTRACE_API_COMPATIBILITY=openai

# ==========================================
# 高级配置（可选）
# ==========================================

# 截图间隔（分钟）
# SCREENTRACE_SCREENSHOT_INTERVAL=10

# 相似度阈值（0-1）
# SCREENTRACE_SIMILARITY_THRESHOLD=0.85

# 数据保留天数
# SCREENTRACE_RETENTION_DAYS=90

# Web面板端口
# SCREENTRACE_DASHBOARD_PORT=8080
